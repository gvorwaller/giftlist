# Path to SQLite database file (WAL mode enabled at startup)
DATABASE_PATH=./data/gifttracker.db

# Secret for signing session cookies (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-long-random-string

# Production app port (dev uses 5175, production uses 3001 per cs.md)
PORT=3001

# --- User seed (consumed by `npm run seed`) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
ADMIN_DISPLAY_NAME=Gaylon
MANAGER_USERNAME=manager
MANAGER_PASSWORD=change-me-manager
MANAGER_DISPLAY_NAME=Manager

# --- Google OAuth2 (Phase 2b/4 — contacts.readonly + gmail.modify) ---
# Create at https://console.cloud.google.com/auth/clients and paste values here.
# Redirect URI must be registered in the OAuth client exactly as written below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5175/admin/settings/google/callback

# --- Scheduler (Phase 4) ---
# Enable in-process cron for reminders + Amazon scan + processed cleanup.
# Requires BOTH NODE_ENV=production AND ENABLE_CRON=true; otherwise the
# scheduler logs "disabled" at boot and registers nothing.
# ENABLE_CRON=true

# --- Notifications (Phase 5) ---
# Reminder digest lead window in days (default 21).
# REMINDER_LEAD_DAYS=21
#
# Email via SMTP (optional). Leave all blank to skip the email channel.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Gift Tracker <noreply@vorwaller.net>"
# SMTP_TO=gaylon@vorwaller.net
#
# Telegram bot (optional). Create a bot via @BotFather, get the token,
# then message the bot once and grab the chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Phase 4: Backups (DigitalOcean Spaces) ---
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_BUCKET=
# SPACES_REGION=
# SPACES_ENDPOINT=
